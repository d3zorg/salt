From 36648d01ab04ab24270b070c6dfed2d27d77d98a Mon Sep 17 00:00:00 2001
From: Denis Safronenkov <dsafronenkov@axcient.com>
Date: Thu, 5 Mar 2026 20:31:05 +0300
Subject: [PATCH 2/2] Track ZMQ publish callbacks futures to prevent leaks

---
 salt/transport/zeromq.py | 33 +++++++++++++++++++++++++++++++--
 1 file changed, 31 insertions(+), 2 deletions(-)

diff --git a/salt/transport/zeromq.py b/salt/transport/zeromq.py
index 2d2f8d3a57..dd9bf4e8dc 100644
--- a/salt/transport/zeromq.py
+++ b/salt/transport/zeromq.py
@@ -287,12 +287,29 @@ class PublishClient(salt.transport.base.PublishClient):
         :param func callback: A function which should be called when data is received
         """
         try:
-            return self.stream.on_recv(callback)
+            if callback is None:
+                return self.stream.on_recv(None)
+            return self.stream.on_recv(self._on_recv_callback(callback))
         except OSError as exc:
             if callback is None and str(exc) == "Stream is closed":
                 return
             raise
 
+    def _on_recv_callback(self, callback):
+        def run_callback(messages):
+            future = callback(messages)
+            if hasattr(future, "add_done_callback"):
+                self.io_loop.add_future(future, self._on_recv_future_done)
+
+        return run_callback
+
+    @staticmethod
+    def _on_recv_future_done(future):
+        try:
+            future.result()
+        except Exception:  # pylint: disable=broad-except
+            log.error("Unhandled exception in publish client callback", exc_info=True)
+
     @salt.ext.tornado.gen.coroutine
     def send(self, msg):
         self.stream.send(msg, noblock=True)
@@ -826,6 +843,13 @@ class PublishServer(salt.transport.base.DaemonizedPublishServer):
     def __init__(self, opts):
         self.opts = opts
 
+    @staticmethod
+    def _on_recv_future_done(future):
+        try:
+            future.result()
+        except Exception:  # pylint: disable=broad-except
+            log.error("Unhandled exception in publisher callback", exc_info=True)
+
     def connect(self):
         return salt.ext.tornado.gen.sleep(5)
 
@@ -888,7 +912,12 @@ class PublishServer(salt.transport.base.DaemonizedPublishServer):
                     exc_info_on_loglevel=logging.DEBUG,
                 )
 
-        pull_sock.on_recv(on_recv)
+        def on_recv_callback(packages):
+            future = on_recv(packages)
+            if hasattr(future, "add_done_callback"):
+                self.io_loop.add_future(future, self._on_recv_future_done)
+
+        pull_sock.on_recv(on_recv_callback)
         try:
             ioloop.start()
         except (KeyboardInterrupt, SystemExit):
-- 
