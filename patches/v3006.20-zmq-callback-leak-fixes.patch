From ef0474b088c6affdea801a5f178c44ebd108a5e8 Mon Sep 17 00:00:00 2001
From: Denis Safronenkov <dsafronenkov@axcient.com>
Date: Thu, 5 Mar 2026 11:30:50 +0300
Subject: [PATCH 1/2] Track ReqServer ZMQ recv coroutine futures explicitly

(cherry picked from commit 9295a065c94ffa4fc7f8cc05c5509be6b0b75919)
---
 salt/transport/zeromq.py | 20 +++++++++++++++++++-
 1 file changed, 19 insertions(+), 1 deletion(-)

diff --git a/salt/transport/zeromq.py b/salt/transport/zeromq.py
index be1d77d6db..2d2f8d3a57 100644
--- a/salt/transport/zeromq.py
+++ b/salt/transport/zeromq.py
@@ -437,8 +437,26 @@ class RequestServer(salt.transport.base.DaemonizedRequestServer):
         ):
             os.chmod(os.path.join(self.opts["sock_dir"], "workers.ipc"), 0o600)
         self.stream = zmq.eventloop.zmqstream.ZMQStream(self._socket, io_loop=io_loop)
+        self.io_loop = io_loop
         self.message_handler = message_handler
-        self.stream.on_recv_stream(self.handle_message)
+        self.stream.on_recv_stream(self._handle_message_callback)
+
+    def _handle_message_callback(self, stream, payload):
+        """
+        ZMQStream recv callbacks are synchronous. If we register a coroutine
+        directly, the returned Future is ignored by ZMQStream and exception
+        handling/completion tracking is left implicit.
+        """
+        future = self.handle_message(stream, payload)
+        if hasattr(future, "add_done_callback"):
+            self.io_loop.add_future(future, self._handle_message_future_done)
+
+    @staticmethod
+    def _handle_message_future_done(future):
+        try:
+            future.result()
+        except Exception:  # pylint: disable=broad-except
+            log.error("Unhandled exception in request server callback", exc_info=True)
 
     @salt.ext.tornado.gen.coroutine
     def handle_message(self, stream, payload):
-- 
